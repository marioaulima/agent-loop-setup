{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.agent/hooks/pre-bash-policy.mjs",
            "statusMessage": "Checking Bash command"
          }
        ]
      },
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.agent/hooks/pre-file-edit-policy.mjs",
            "statusMessage": "Checking file edit policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.agent/hooks/post-edit-format.mjs",
            "statusMessage": "Running post-edit formatter"
          }
        ]
      },
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.agent/hooks/post-edit-tracker.mjs",
            "statusMessage": "Tracking edited files"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.agent/hooks/stop-reminder.mjs",
            "statusMessage": "Checking session stop state"
          }
        ]
      }
    ]
  }
}
